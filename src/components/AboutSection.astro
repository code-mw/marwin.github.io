---
interface Props {
  paragraphs: string[];
}
const { paragraphs } = Astro.props;
---

<section id="about" class="site-container pt-16 pb-8">
  <h2 class="section-heading text-gray-900 dark:text-white" id="about-heading">
    About
  </h2>

  <div class="grid grid-cols-1 items-start gap-8 sm:grid-cols-[3fr_1fr]">
    <div>
      {
        paragraphs.map((paragraph) => (
          <p class="about-body mb-6 leading-relaxed text-gray-600 last:mb-0 dark:text-gray-400">
            {paragraph}
          </p>
        ))
      }
    </div>

    <a href="/chat" id="ai-card" aria-label="Chat with AI assistant">
      <div id="ai-card-glow" aria-hidden="true"></div>
      <p id="ai-card-body">Have a question?</p>
      <div id="ai-card-icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            fill-rule="evenodd"
            d="M9 4.5a.75.75 0 0 1 .721.544l.813 2.846a3.75 3.75 0 0 0 2.576 2.576l2.846.813a.75.75 0 0 1 0 1.442l-2.846.813a3.75 3.75 0 0 0-2.576 2.576l-.813 2.846a.75.75 0 0 1-1.442 0l-.813-2.846a3.75 3.75 0 0 0-2.576-2.576l-2.846-.813a.75.75 0 0 1 0-1.442l2.846-.813A3.75 3.75 0 0 0 7.466 7.89l.813-2.846A.75.75 0 0 1 9 4.5Zm9 7.5a.75.75 0 0 1 .721.544l.405 1.415a1.875 1.875 0 0 0 1.288 1.288l1.415.405a.75.75 0 0 1 0 1.442l-1.415.405a1.875 1.875 0 0 0-1.288 1.288l-.405 1.415a.75.75 0 0 1-1.442 0l-.405-1.415a1.875 1.875 0 0 0-1.288-1.288l-1.415-.405a.75.75 0 0 1 0-1.442l1.415-.405a1.875 1.875 0 0 0 1.288-1.288l.405-1.415A.75.75 0 0 1 18 12Z"
            clip-rule="evenodd"></path>
        </svg>
      </div>
      <div id="ai-card-btn">
        Start chatting!
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M16.72 7.72a.75.75 0 0 1 1.06 0l3.75 3.75a.75.75 0 0 1 0 1.06l-3.75 3.75a.75.75 0 1 1-1.06-1.06l2.47-2.47H3a.75.75 0 0 1 0-1.5h16.19l-2.47-2.47a.75.75 0 0 1 0-1.06Z"
            clip-rule="evenodd"></path>
        </svg>
      </div>
    </a>
  </div>
</section>

<style>
  @layer components {
    #about-heading {
      margin-bottom: 1.25rem;
    }

    .about-body {
      font-size: clamp(0.9375rem, 1.1vw, 1.0625rem);
    }

    #ai-card {
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      gap: 0.875rem;
      width: 100%;
      padding: 15px;
      border-radius: 1.25rem;
      background: linear-gradient(145deg, #0f172a 0%, #1e1b4b 100%);
      border: 1px solid rgba(148, 163, 184, 0.12);
      box-shadow: 0 8px 32px rgba(15, 23, 42, 0.35);
      text-decoration: none;
      overflow: hidden;
      transition:
        transform 0.2s ease,
        box-shadow 0.2s ease;
    }

    #ai-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 40px rgba(99, 102, 241, 0.35);
    }

    #ai-card-glow {
      position: absolute;
      top: -40%;
      right: -20%;
      width: 70%;
      aspect-ratio: 1;
      background: radial-gradient(
        circle,
        rgba(99, 102, 241, 0.35) 0%,
        transparent 70%
      );
      pointer-events: none;
      animation: glow-pulse 4s ease-in-out infinite;
    }

    @keyframes glow-pulse {
      0%,
      100% {
        opacity: 0.6;
        transform: scale(1);
      }
      50% {
        opacity: 1;
        transform: scale(1.15);
      }
    }

    #ai-card-icon {
      width: 2.5rem;
      height: 2.5rem;
      border-radius: 0.625rem;
      background: rgba(99, 102, 241, 0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    #ai-card-icon svg {
      width: 1.25rem;
      height: 1.25rem;
      color: var(--color-indigo-300);
    }

    #ai-card-body {
      font-size: 0.9375rem;
      line-height: 1.5;
      color: var(--color-slate-300);
      margin: 0;
      font-family: ui-monospace, "Cascadia Code", "Fira Code", monospace;
    }

    #ai-card-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.25rem;
      padding: 0.625rem 1rem;
      border-radius: 0.625rem;
      background: linear-gradient(135deg, #6366f1, #3b82f6);
      color: white;
      font-size: 0.875rem;
      font-weight: 600;
      font-family: ui-monospace, "Cascadia Code", "Fira Code", monospace;
      box-shadow: 0 0 16px rgba(99, 102, 241, 0.45);
      transition:
        box-shadow 0.2s ease,
        filter 0.2s ease;
    }

    #ai-card:hover #ai-card-btn {
      box-shadow: 0 0 24px rgba(99, 102, 241, 0.7);
      filter: brightness(1.1);
    }

    #ai-card-btn svg {
      width: 0.875rem;
      height: 0.875rem;
      flex-shrink: 0;
      transition: transform 0.2s ease;
    }

    #ai-card:hover #ai-card-btn svg {
      transform: translateX(3px);
    }

    @media (prefers-reduced-motion: reduce) {
      #ai-card,
      #ai-card-btn,
      #ai-card-btn svg,
      #ai-card-glow {
        transition: none;
        animation: none;
      }
    }
  }
</style>
