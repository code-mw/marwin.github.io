---
import { profile, levelLabel } from "../data/profile";
import avatarImg from "../assets/avatar.jpg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{profile.firstName} {profile.lastName} — CV</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@600;700&family=Plus+Jakarta+Sans:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <div class="print-bar">
      <span class="print-bar-label"
        >{profile.firstName} {profile.lastName} &mdash; CV</span
      >
      <button id="cv-print-btn" type="button" class="print-btn">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Download PDF
      </button>
    </div>

    <div class="page-wrap">
      <article class="cv">
        <header class="cv-header">
          <div class="cv-identity">
            <h1 class="cv-name">{profile.firstName} {profile.lastName}</h1>
            <p class="cv-role">{profile.tagline}</p>
            <a href={profile.website} class="cv-link cv-website">{profile.websiteHandle}</a>
            <div class="cv-contacts">
              <span class="cv-contacts-label">Contacts</span>
              <a href={`mailto:${profile.email}`} class="cv-link">{profile.email}</a>
              <a href={profile.linkedin} class="cv-link">linkedin/{profile.linkedinHandle}</a>
            </div>
          </div>
          <div class="cv-contact-block">
            <img src={avatarImg.src} alt="" class="cv-avatar" />
          </div>
        </header>

        <div class="cv-divider">
          <div class="cv-divider-line"></div>
        </div>

        <div class="cv-body">
          <main class="cv-main">
            <section class="cv-section">
              <h2 class="cv-section-label">Profile</h2>
              {profile.about.map((p) => <p class="cv-para">{p}</p>)}
            </section>

            <section class="cv-section">
              <h2 class="cv-section-label">Experience</h2>
              {profile.experience.map((entry, i) => (
                <div class="exp-entry">
                  <div class="exp-company-row">
                    {entry.current && <span class="exp-current-badge">Currently</span>}
                    <span class="exp-company">{entry.company}</span>
                    {(entry.employmentType || entry.totalDuration) && (
                      <span class="exp-company-meta">
                        {[entry.employmentType, entry.totalDuration].filter(Boolean).join(" · ")}
                      </span>
                    )}
                  </div>
                  {entry.roles.map((role, i) => (
                    <div class={`exp-role${i > 0 ? " exp-role--subsequent" : ""}`}>
                      <div class="exp-role-header">
                        <span class="exp-role-title">{role.title}</span>
                        <span class="exp-role-period">{role.period}</span>
                      </div>
                      <span class="exp-role-location">{role.location}</span>
                      <ul class="exp-bullets">
                        {role.bullets.map((b) => <li class="exp-bullet">{b}</li>)}
                      </ul>
                    </div>
                  ))}
                </div>
              ))}
            </section>
          </main>

          <aside class="cv-sidebar">
            {
              profile.skills.map((cat) => (
                <div class="skill-group">
                  <h2 class="cv-section-label">{cat.name}</h2>
                  <ul class="skill-list">
                    {cat.skills.map((skill) => (
                      <li class="skill-row">
                        <span class="skill-name">{skill.name}</span>
                        <div
                          class="skill-pips"
                          aria-label={levelLabel(skill.level)}
                        >
                          {[1, 2, 3, 4, 5].map((i) => (
                            <span
                              class={`pip ${i <= skill.level ? "pip--on" : "pip--off"}`}
                            />
                          ))}
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </aside>
        </div>
      </article>
    </div>
  </body>
</html>

<style>
  /* ── Reset ─────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  a {
    color: inherit;
    text-decoration: none;
  }

  /* ── Tokens ─────────────────────────────────────────── */
  :root {
    --ink: #0f172a;
    --ink-mid: #475569;
    --ink-muted: #94a3b8;
    --accent: #1d4ed8;
    --border: #e2e8f0;
    --bg-page: #f1f5f9;
    --font-head: "Raleway", sans-serif;
    --font-body: "Plus Jakarta Sans", sans-serif;
  }

  /* ── Screen chrome ───────────────────────────────────── */
  body {
    background: var(--bg-page);
    font-family: var(--font-body);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
  }

  .print-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.6rem 1.5rem;
    background: var(--ink);
    color: #e2e8f0;
    font-family: var(--font-body);
    font-size: 0.8125rem;
  }

  .print-bar-label {
    opacity: 0.5;
    letter-spacing: 0.02em;
  }

  .print-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: background 0.15s;
  }
  .print-btn:hover {
    background: #1e40af;
  }

  /* ── Page wrapper ─────────────────────────────────── */
  .page-wrap {
    padding: calc(36px + 2rem) 1.5rem 2rem;
    display: flex;
    justify-content: center;
  }

  /* ── CV document ──────────────────────────────────── */
  .cv {
    width: 100%;
    max-width: 794px; /* 210mm @ 96dpi */
    min-height: 1122px; /* 297mm @ 96dpi */
    background: #fff;
    padding: 48px 52px;
    box-shadow:
      0 2px 32px rgba(0, 0, 0, 0.1),
      0 1px 4px rgba(0, 0, 0, 0.06);
  }

  /* ── Header ───────────────────────────────────────── */
  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    margin-bottom: 1rem;
    overflow: visible;
  }

  .cv-identity {
    overflow: visible;
    padding-bottom: 0.5rem;
  }

  .cv-name {
    font-family: var(--font-head);
    font-size: 1.625rem;
    font-weight: 700;
    line-height: 1.4;
    letter-spacing: -0.02em;
    color: var(--ink);
    overflow: visible;
  }

  .cv-role {
    margin-top: 0.2rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ink-mid);
    letter-spacing: 0.01em;
  }

  .cv-contact-block {
    flex-shrink: 0;
  }

  .cv-avatar {
    width: 156px;
    height: 156px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 20%;
  }

  .cv-website {
    display: block;
    margin-top: 0.35rem;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .cv-contacts {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-top: 0.75rem;
  }

  .cv-contacts-label {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.15rem;
  }

  .cv-link {
    font-size: 0.8125rem;
    color: var(--accent);
    font-weight: 500;
  }
  .cv-link:hover {
    text-decoration: underline;
  }

  /* ── Divider ──────────────────────────────────────── */
  .cv-divider {
    margin-bottom: 1.5rem;
  }

  .cv-divider-line {
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--accent) 0%,
      var(--accent) 40%,
      var(--border) 40%
    );
  }

  /* ── Body layout ──────────────────────────────────── */
  .cv-body {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Section label ────────────────────────────────── */
  .cv-section-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    margin-bottom: 0.625rem;
  }

  /* ── Profile text ─────────────────────────────────── */
  .cv-section {
    margin-bottom: 1.5rem;
  }

  .cv-para {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--ink-mid);
    margin-bottom: 0.75rem;
  }
  .cv-para:last-child {
    margin-bottom: 0;
  }

  /* ── Skills sidebar ───────────────────────────────── */
  .cv-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-group {
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }

  .skill-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .skill-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .skill-name {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--ink);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .skill-pips {
    display: flex;
    gap: 2px;
    flex-shrink: 0;
  }

  .pip {
    display: block;
    width: 14px;
    height: 4px;
    border-radius: 2px;
  }
  .pip--on {
    background: var(--accent);
  }
  .pip--off {
    background: var(--border);
  }

  /* ── Experience ───────────────────────────────────── */
  .exp-entry {
    margin-bottom: 1.25rem;
    border-top: 1px solid var(--border);
    padding-top: 0.75rem;
  }
  .exp-entry:first-child {
    border-top: none;
    padding-top: 0;
  }

  .exp-company-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .exp-company {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--ink);
  }

  .exp-company-meta {
    font-size: 0.75rem;
    color: var(--ink-muted);
  }

  .exp-current-badge {
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 3px;
    padding: 0.1em 0.4em;
    line-height: 1.6;
    flex-shrink: 0;
  }

  .exp-role {
    margin-bottom: 0.75rem;
  }
  .exp-role--subsequent {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px dashed var(--border);
  }
  .exp-role:last-child {
    margin-bottom: 0;
  }

  .exp-role-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.15rem;
  }

  .exp-role-title {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ink);
  }

  .exp-role-period {
    font-size: 0.75rem;
    color: var(--ink-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .exp-role-location {
    display: block;
    font-size: 0.75rem;
    color: var(--ink-muted);
    margin-bottom: 0.4rem;
  }

  .exp-bullets {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .exp-bullet {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: var(--ink-mid);
    padding-left: 0.85rem;
    position: relative;
  }
  .exp-bullet::before {
    content: "–";
    position: absolute;
    left: 0;
    color: var(--ink-muted);
  }

  /* ── Print ────────────────────────────────────────── */
  @media print {
    @page {
      size: A4;
      margin: 15mm 18mm;
    }

    body {
      background: #fff;
    }

    .print-bar {
      display: none;
    }

    .page-wrap {
      padding: 0;
      display: block;
    }

    .cv {
      box-shadow: none;
      padding: 0;
      max-width: none;
      min-height: auto;
    }

    .cv-body {
      grid-template-columns: 1fr 190px;
    }

    .cv-para {
      color: #334155;
    }
    .pip--off {
      background: #e2e8f0;
    }

  }
</style>

<script>
  document
    .getElementById("cv-print-btn")
    ?.addEventListener("click", () => window.print());
</script>
