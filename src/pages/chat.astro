---
import Layout from "../layouts/Layout.astro";
import { profile } from "../data/profile";

const WORKER_URL = import.meta.env.PUBLIC_WORKER_URL;
---

<Layout
  title={`Chat — ${profile.firstName} ${profile.lastName}`}
  description={`Chat with ${profile.firstName}'s AI assistant about his background, skills, and experience.`}
>
  <div id="chat-page" data-worker-url={WORKER_URL}>
    <header id="chat-header">
      <a href="/" id="chat-back" aria-label="Back to site">
        <svg
          width="16"
          height="16"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M11.03 3.97a.75.75 0 0 1 0 1.06l-6.22 6.22H21a.75.75 0 0 1 0 1.5H4.81l6.22 6.22a.75.75 0 1 1-1.06 1.06l-7.5-7.5a.75.75 0 0 1 0-1.06l7.5-7.5a.75.75 0 0 1 1.06 0Z"
            clip-rule="evenodd"></path>
        </svg>
        Back
      </a>
      <div id="chat-title">
        <div id="chat-status-dot" aria-hidden="true"></div>
        <span>AI Assistant</span>
      </div>
      <div id="chat-header-spacer" aria-hidden="true"></div>
    </header>

    <div
      id="chat-messages"
      role="log"
      aria-live="polite"
      aria-label="Chat messages"
    >
    </div>

    <div id="chat-input-bar">
      <form id="chat-form">
        <input
          type="text"
          id="chat-input"
          placeholder={`Ask me about ${profile.firstName}'s background, skills or experience…`}
          autocomplete="off"
          aria-label="Message"
        />
        <button type="submit" id="chat-send" aria-label="Send">
          <svg
            width="18"
            height="18"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M3.478 2.404a.75.75 0 0 0-.926.941l2.432 7.905H13.5a.75.75 0 0 1 0 1.5H4.984l-2.432 7.905a.75.75 0 0 0 .926.94 60.519 60.519 0 0 0 18.445-8.986.75.75 0 0 0 0-1.218A60.517 60.517 0 0 0 3.478 2.404Z"
            ></path>
          </svg>
        </button>
      </form>
    </div>
  </div>
</Layout>

<style is:global>
  html,
  body {
    height: 100%;
    overflow: hidden;
  }
</style>

<style>
  @layer components {
    #chat-page {
      display: flex;
      flex-direction: column;
      height: 100%;
      max-width: 760px;
      margin: 0 auto;
    }

    #chat-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.875rem 1.25rem;
      border-bottom: 1px solid var(--color-gray-200);
      flex-shrink: 0;
      background: white;
      position: sticky;
      top: 0;
      z-index: 10;
    }

    #chat-back {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--color-gray-500);
      text-decoration: none;
      transition: color 0.15s ease;
      min-width: 80px;
    }

    #chat-back:hover {
      color: var(--color-gray-900);
    }

    #chat-back svg {
      width: 1rem;
      height: 1rem;
    }

    #chat-title {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-gray-900);
    }

    #chat-status-dot {
      width: 0.5rem;
      height: 0.5rem;
      border-radius: 9999px;
      background: var(--color-green-400);
      flex-shrink: 0;
    }

    #chat-header-spacer {
      min-width: 80px;
    }

    #chat-messages {
      flex: 1;
      overflow-y: auto;
      padding: 1.5rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    :global(.chat-bubble) {
      max-width: 75%;
      padding: 0.75rem 1rem;
      border-radius: 1.125rem;
      font-size: 0.9375rem;
      line-height: 1.6;
      word-break: break-word;
    }

    :global(.chat-bubble--user) {
      align-self: flex-end;
      background: #e8f0fe;
      color: #1e3a5f;
      border-bottom-right-radius: 0.25rem;
      white-space: pre-wrap;
    }

    :global(.chat-bubble--assistant) {
      align-self: flex-start;
      background: var(--color-gray-100);
      color: var(--color-gray-900);
      border-bottom-left-radius: 0.25rem;
    }

    :global(.chat-bubble--assistant.error) {
      background: var(--color-red-50);
      color: var(--color-red-700);
    }

    :global(.chat-bubble--assistant.typing) {
      color: var(--color-gray-400);
    }

    :global(.chat-bubble--assistant p) {
      margin: 0 0 0.6em;
    }
    :global(.chat-bubble--assistant p:last-child) {
      margin-bottom: 0;
    }
    :global(.chat-bubble--assistant ul),
    :global(.chat-bubble--assistant ol) {
      margin: 0.4em 0 0.6em 1.25em;
      padding: 0;
    }
    :global(.chat-bubble--assistant li) {
      margin-bottom: 0.25em;
    }
    :global(.chat-bubble--assistant code) {
      font-family: ui-monospace, monospace;
      font-size: 0.85em;
      background: rgba(0, 0, 0, 0.07);
      padding: 0.15em 0.35em;
      border-radius: 0.25rem;
    }
    :global(.chat-bubble--assistant pre) {
      background: rgba(0, 0, 0, 0.07);
      border-radius: 0.5rem;
      padding: 0.75em 1em;
      margin: 0.5em 0;
      overflow-x: auto;
    }
    :global(.chat-bubble--assistant pre code) {
      background: none;
      padding: 0;
      font-size: 0.85em;
    }
    :global(.chat-bubble--assistant strong) {
      font-weight: 600;
    }
    :global(.chat-bubble--assistant h1),
    :global(.chat-bubble--assistant h2),
    :global(.chat-bubble--assistant h3) {
      font-weight: 600;
      margin: 0.75em 0 0.35em;
      line-height: 1.3;
    }
    :global(.chat-bubble--assistant h1) {
      font-size: 1.1em;
    }
    :global(.chat-bubble--assistant h2) {
      font-size: 1.05em;
    }
    :global(.chat-bubble--assistant h3) {
      font-size: 1em;
    }

    #chat-input-bar {
      flex-shrink: 0;
      border-top: 1px solid var(--color-gray-200);
      padding: 1rem 1.25rem;
      background: white;
    }

    #chat-form {
      display: flex;
      gap: 0.625rem;
      align-items: center;
    }

    #chat-input {
      flex: 1;
      border: 1px solid var(--color-gray-300);
      border-radius: 0.75rem;
      padding: 0.75rem 1rem;
      font-size: 0.9375rem;
      font-family: inherit;
      background: white;
      color: var(--color-gray-900);
      outline: none;
      transition: border-color 0.15s ease;
    }

    #chat-input:focus {
      border-color: var(--color-blue-600);
    }

    #chat-input:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    #chat-send {
      width: 2.75rem;
      height: 2.75rem;
      flex-shrink: 0;
      border-radius: 0.75rem;
      background: var(--color-blue-600);
      color: white;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background-color 0.15s ease;
    }

    #chat-send:hover {
      background: var(--color-blue-700);
    }

    #chat-send:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    #chat-send svg {
      width: 1.125rem;
      height: 1.125rem;
    }

    @media (prefers-color-scheme: dark) {
      #chat-header {
        background: var(--color-slate-900);
        border-bottom-color: var(--color-slate-800);
      }

      #chat-back {
        color: var(--color-slate-400);
      }

      #chat-back:hover {
        color: var(--color-slate-100);
      }

      #chat-title {
        color: var(--color-slate-100);
      }

      :global(.chat-bubble--user) {
        background: #1e3a5f;
        color: var(--color-blue-200);
      }

      :global(.chat-bubble--assistant) {
        background: var(--color-slate-800);
        color: var(--color-slate-100);
      }

      :global(.chat-bubble--assistant.error) {
        background: var(--color-red-950);
        color: var(--color-red-300);
      }

      :global(.chat-bubble--assistant.typing) {
        color: var(--color-slate-600);
      }

      #chat-input-bar {
        background: var(--color-slate-900);
        border-top-color: var(--color-slate-800);
      }

      #chat-input {
        background: var(--color-slate-800);
        border-color: var(--color-slate-700);
        color: var(--color-slate-100);
      }

      #chat-input:focus {
        border-color: var(--color-blue-500);
      }
    }

    @media (max-width: 480px) {
      :global(.chat-bubble) {
        max-width: 88%;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #chat-input,
      #chat-send,
      #chat-back {
        transition: none;
      }
    }
  }
</style>

<script>
  import {
    createClient,
    RateLimitError,
    NetworkError,
  } from "@code-mw/anthropic-proxy-client";
  import type { Message } from "@code-mw/anthropic-proxy-client";
  import { marked } from "marked";
  import DOMPurify from "dompurify";

  marked.setOptions({ breaks: true, async: false });

  function byId<T extends HTMLElement>(id: string): T {
    const el = document.getElementById(id);
    if (!el) throw new Error(`Missing #${id}`);
    return el as T;
  }

  const page = byId<HTMLDivElement>("chat-page");
  const messagesEl = byId<HTMLDivElement>("chat-messages");
  const form = byId<HTMLFormElement>("chat-form");
  const input = byId<HTMLInputElement>("chat-input");
  const sendBtn = byId<HTMLButtonElement>("chat-send");

  const workerUrl = page.dataset.workerUrl;
  if (!workerUrl) console.warn("PUBLIC_WORKER_URL is not set");

  function syncHeight() {
    page.style.height = `${window.visualViewport?.height ?? window.innerHeight}px`;
  }
  window.visualViewport?.addEventListener("resize", syncHeight);
  window.addEventListener("orientationchange", syncHeight);
  window.addEventListener("pagehide", () => {
    window.visualViewport?.removeEventListener("resize", syncHeight);
    window.removeEventListener("orientationchange", syncHeight);
  });
  syncHeight();

  const client = createClient({ workerUrl: workerUrl ?? "" });
  const canHover = !window.matchMedia("(hover: none)").matches;

  const messages: Message[] = [];

  function renderMarkdown(text: string): string {
    const html = marked.parse(text);
    if (typeof html !== "string") return DOMPurify.sanitize(text);
    return DOMPurify.sanitize(html);
  }

  function appendBubble(
    role: string,
    text: string,
    extra?: string,
  ): HTMLDivElement {
    const bubble = document.createElement("div");
    bubble.className = `chat-bubble chat-bubble--${role}${extra ? " " + extra : ""}`;
    if (role === "assistant" && !extra) {
      bubble.innerHTML = renderMarkdown(text);
    } else {
      bubble.textContent = text;
    }
    messagesEl.appendChild(bubble);
    scrollToBottom();
    return bubble;
  }

  function scrollToBottom() {
    requestAnimationFrame(() => {
      messagesEl.scrollTop = messagesEl.scrollHeight;
    });
  }

  appendBubble(
    "assistant",
    "Hi! I'm Marcin's AI assistant. Ask me about his background, skills, or experience.",
  );

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const text = input.value.trim();
    if (!text || sendBtn.disabled) return;

    input.value = "";
    input.disabled = true;
    sendBtn.disabled = true;

    appendBubble("user", text);
    messages.push({ role: "user", content: text });

    const assistantBubble = appendBubble("assistant", "…", "typing");

    try {
      let full = "";
      for await (const chunk of client.chat(messages)) {
        if (assistantBubble.classList.contains("typing")) {
          assistantBubble.classList.remove("typing");
        }
        full += chunk;
        assistantBubble.innerHTML = renderMarkdown(full);
        scrollToBottom();
      }
      if (full) {
        messages.push({ role: "assistant", content: full });
      } else {
        assistantBubble.textContent = "No response received.";
        messages.pop();
      }
    } catch (err) {
      messages.pop();
      assistantBubble.classList.remove("typing");
      assistantBubble.classList.add("error");
      if (err instanceof RateLimitError) {
        const mins = Math.ceil(err.retryAfter / 60);
        assistantBubble.textContent = `Too many messages. Try again in ${mins} minute${mins !== 1 ? "s" : ""}.`;
      } else if (err instanceof NetworkError) {
        assistantBubble.textContent =
          "Connection failed. Check your network and try again.";
      } else {
        assistantBubble.textContent = "Something went wrong. Please try again.";
      }
    } finally {
      input.disabled = false;
      sendBtn.disabled = false;
      if (canHover) input.focus();
    }
  });

  if (canHover) input.focus();
</script>
